
"""
Decentralized Swarm Consensus Simulation for Disaster Triage UAVs

ALGORITHM (v3):
  Gossip does two things:
  1. SURVIVOR DECONFLICTION — claim tags so drones don't double-assess
  2. SPATIAL DECONFLICTION — share drone positions so drones spread out
     and cover DIFFERENT areas instead of clustering

  random: truly random waypoints, no position sharing → cluster
  gossip: waypoints maximize distance from known drone positions → spread
  centralized: same as gossip but perfect broadcast of all positions

SETUP:  pip install matplotlib numpy scipy pandas tqdm

USAGE:
  python swarm_sim.py --mode visualize --protocol gossip      --ploss 0.0
  python swarm_sim.py --mode visualize --protocol random      --ploss 0.5
  python swarm_sim.py --mode visualize --protocol centralized --ploss 0.0
  python swarm_sim.py --mode visualize --protocol gossip      --ge
  python swarm_sim.py --mode benchmark
  python swarm_sim.py --mode benchmark --trials 1000
  python swarm_sim.py --mode analyze
"""

import argparse, copy, math, os, random, sys
import numpy as np
import matplotlib
import matplotlib.pyplot as plt
import matplotlib.animation as animation
import matplotlib.patches as mpatches
from matplotlib.lines import Line2D
from matplotlib.gridspec import GridSpec
import pandas as pd
from scipy import stats as scipy_stats

try:
    from tqdm import tqdm
except ImportError:
    def tqdm(it, **kw): return it

# ══════════════════════════════════════════════════════════════════════
#  CONSTANTS
# ══════════════════════════════════════════════════════════════════════
FIELD        = 200
N_SURV       = 30
N_DRONES     = 3
SPEED        = 12.0
DT           = 0.5
T_MAX        = 600_000
R_DETECT     = 20.0
R_ASSESS     = 5.0
T_ASSESS     = 5.0
R_COMM       = 250.0
GOSSIP_K     = 2
N_TRIALS     = 1000
P_LOSS_LIST  = [0.0, 0.2, 0.5, 0.8]
CRIT_RATE    = 0.3
WP_CANDIDATES = 30   # candidates sampled when picking spread-out waypoint

GE_P_GB      = 0.10
GE_P_BG      = 0.25
GE_PLOSS_G   = 0.05
GE_PLOSS_B   = 0.80

PROTO_INFO = {
    "gossip":      ("Gossip Consensus",           "#2196F3"),
    "random":      ("Random Search (No Comm)",    "#F44336"),
    "centralized": ("Centralized (Perfect Comm)", "#4CAF50"),
}

_RANK = {"assessed": 4, "assessing": 3, "claimed": 2, "detected": 1}


# ══════════════════════════════════════════════════════════════════════
#  HELPERS
# ══════════════════════════════════════════════════════════════════════
def _dist(ax, ay, bx, by):
    return math.hypot(ax - bx, ay - by)


# ══════════════════════════════════════════════════════════════════════
#  DATA CLASSES
# ══════════════════════════════════════════════════════════════════════
class Survivor:
    def __init__(self, sid):
        self.id       = sid
        self.x        = random.uniform(0, FIELD)
        self.y        = random.uniform(0, FIELD)
        self.critical = random.random() < CRIT_RATE
        self.hr       = random.randint(50, 140)
        self.rr       = random.randint(8,  30)
        self.temp     = round(random.uniform(35.0, 40.0), 1)


class Drone:
    def __init__(self, did):
        self.id           = did
        self.x            = random.uniform(0, FIELD)
        self.y            = random.uniform(0, FIELD)
        # Survivor knowledge: sid → record
        self.known        = {}
        # Known drone positions (from gossip): drone_id → (x, y)
        # random protocol: always empty; gossip/centralized: populated
        self.known_drones = {}
        self.target_id    = None
        self.assessing_id = None
        self.assess_start = None
        self.waypoint     = (random.uniform(0, FIELD),
                             random.uniform(0, FIELD))
        self.state        = "SEARCH"
        self.last_tx_peer = None


# ══════════════════════════════════════════════════════════════════════
#  SIMULATION ENGINE
# ══════════════════════════════════════════════════════════════════════
class SwarmSim:
    """
    v3: gossip shares both survivor claims AND drone positions.
    Drones use known positions to pick waypoints that maximise
    distance from teammates → genuine spatial coverage coordination.
    Random protocol never shares positions → random overlap/clustering.
    """

    def __init__(self, protocol="gossip", p_loss=0.0,
                 ge_model=False, seed=0):
        random.seed(seed)
        self.protocol  = protocol
        self.p_loss    = p_loss
        self.ge_model  = ge_model
        self.t         = 0.0
        self.done      = False
        self.t_all     = None
        self.n_dup     = 0
        self.bytes_tx  = 0
        self.n_msgs    = 0

        self.survivors    = [Survivor(i) for i in range(N_SURV)]
        self.drones       = [Drone(i)    for i in range(N_DRONES)]
        self.n_critical   = sum(s.critical for s in self.survivors)
        self.first_crit_t = None
        self.assessed_ids = set()
        self.comm_flash   = []

        self._ch = {}
        if ge_model:
            for i in range(N_DRONES):
                for j in range(N_DRONES):
                    if i != j:
                        self._ch[(i, j)] = "good"

    # ── packet drop ───────────────────────────────────────────────
    def _drop(self, si, ri):
        if self.ge_model:
            k    = (si, ri)
            st   = self._ch.get(k, "good")
            drop = random.random() < (GE_PLOSS_B if st == "bad" else GE_PLOSS_G)
            if st == "good":
                if random.random() < GE_P_GB: self._ch[k] = "bad"
            else:
                if random.random() < GE_P_BG: self._ch[k] = "good"
            return drop
        return random.random() < self.p_loss

    # ── merge survivor tables ─────────────────────────────────────
    @staticmethod
    def _merge(dst, src):
        for sid, s in src.items():
            if sid not in dst:
                dst[sid] = copy.deepcopy(s)
                continue
            e  = dst[sid]
            rs = _RANK.get(s["status"], 0)
            re = _RANK.get(e["status"], 0)
            if rs > re:
                dst[sid] = copy.deepcopy(s)
            elif rs == re:
                sc = s.get("claimed_by")
                ec = e.get("claimed_by")
                if sc is not None and ec is not None and sc < ec:
                    dst[sid] = copy.deepcopy(s)
                elif sc is not None and ec is None:
                    dst[sid] = copy.deepcopy(s)
                elif s.get("ts", 0) > e.get("ts", 0):
                    dst[sid] = copy.deepcopy(s)

    # ── pick a spread-out waypoint ─────────────────────────────────
    def _pick_waypoint(self, drone):
        """
        random protocol  → purely random (no position awareness)
        gossip/centralized → sample WP_CANDIDATES points, keep the one
                             that maximises minimum distance to all known
                             drone positions including self.
                             This spreads drones across uncovered field.
        """
        if self.protocol == "random" or not drone.known_drones:
            return random.uniform(0, FIELD), random.uniform(0, FIELD)

        # Positions to stay away from: teammates + self
        occupied = list(drone.known_drones.values())
        occupied.append((drone.x, drone.y))

        best_pt    = None
        best_score = -1.0
        for _ in range(WP_CANDIDATES):
            cx = random.uniform(0, FIELD)
            cy = random.uniform(0, FIELD)
            score = min(_dist(cx, cy, px, py) for px, py in occupied)
            if score > best_score:
                best_score = score
                best_pt    = (cx, cy)
        return best_pt

    # ── phase 1: thermal detection ────────────────────────────────
    def _detect(self):
        for drone in self.drones:
            for s in self.survivors:
                if s.id in drone.known:
                    continue
                if _dist(drone.x, drone.y, s.x, s.y) < R_DETECT:
                    drone.known[s.id] = {
                        "x":          s.x,
                        "y":          s.y,
                        "status":     "detected",
                        "claimed_by": None,
                        "critical":   s.critical,
                        "conf":       round(random.uniform(0.7, 1.0), 2),
                        "ts":         self.t,
                    }

    # ── phase 2: communication ────────────────────────────────────
    def _comm(self):
        if self.protocol == "random":
            return  # zero communication — no survivor data, no positions

        for sender in self.drones:
            in_range = [
                d for d in self.drones
                if d.id != sender.id
                and _dist(sender.x, sender.y, d.x, d.y) <= R_COMM
            ]
            if not in_range:
                continue

            targets = (
                random.sample(in_range, min(GOSSIP_K, len(in_range)))
                if self.protocol == "gossip"
                else in_range
            )

            # Message payload: survivor table + current position
            msg_bytes = max(len(sender.known), 1) * 64 + N_DRONES * 16

            for recip in targets:
                if self._drop(sender.id, recip.id):
                    continue

                # Share survivor knowledge
                self._merge(recip.known, sender.known)

                # ── KEY FIX: share drone positions ──────────────
                # Recipient now knows where sender is (and everyone
                # sender knows about) → can pick spread-out waypoints
                recip.known_drones[sender.id] = (sender.x, sender.y)
                for did, pos in sender.known_drones.items():
                    if did != recip.id:
                        recip.known_drones[did] = pos

                # Force re-evaluate target if gossip invalidated it
                if (recip.target_id is not None
                        and recip.target_id in recip.known):
                    info = recip.known[recip.target_id]
                    if (info["status"] == "claimed"
                            and info["claimed_by"] != recip.id):
                        recip.target_id = None

                sender.last_tx_peer = recip.id
                self.bytes_tx += msg_bytes
                self.n_msgs   += 1
                self.comm_flash.append(
                    [sender.x, sender.y, recip.x, recip.y, 0])

    # ── phase 3: movement and assessment ─────────────────────────
    def _move(self):
        for drone in self.drones:

            # Update own position in known_drones (always current)
            drone.known_drones[drone.id] = (drone.x, drone.y)

            # ── finish ongoing assessment ──────────────────────
            if drone.assessing_id is not None:
                if self.t - drone.assess_start >= T_ASSESS:
                    sid = drone.assessing_id
                    if sid in self.assessed_ids:
                        self.n_dup += 1
                    else:
                        self.assessed_ids.add(sid)
                        s = self.survivors[sid]
                        if s.critical and self.first_crit_t is None:
                            self.first_crit_t = self.t
                    drone.known[sid].update({
                        "status":     "assessed",
                        "claimed_by": None,
                        "ts":         self.t,
                    })
                    drone.assessing_id = None
                    drone.target_id    = None
                    drone.state        = "SEARCH"
                continue

            # ── release invalid target ─────────────────────────
            if drone.target_id is not None:
                info     = drone.known.get(drone.target_id)
                released = (
                    info is None
                    or info["status"] == "assessed"
                    or (info["status"] in ("claimed", "assessing")
                        and info.get("claimed_by") != drone.id)
                )
                if released:
                    drone.target_id = None

            # ── pick a new target ──────────────────────────────
            if drone.target_id is None:
                best_sid, best_d = None, float("inf")
                for sid, info in drone.known.items():
                    if info["status"] == "assessed":
                        continue
                    if (info["status"] in ("claimed", "assessing")
                            and info.get("claimed_by") != drone.id):
                        continue
                    d = _dist(drone.x, drone.y, info["x"], info["y"])
                    if d < best_d:
                        best_d, best_sid = d, sid

                if best_sid is not None:
                    drone.known[best_sid].update({
                        "status":     "claimed",
                        "claimed_by": drone.id,
                        "ts":         self.t,
                    })
                    drone.target_id = best_sid

            # ── move toward target or spread-out waypoint ──────
            if drone.target_id is not None:
                info   = drone.known[drone.target_id]
                tx, ty = info["x"], info["y"]
                d      = _dist(drone.x, drone.y, tx, ty)
                if d < R_ASSESS:
                    drone.assessing_id = drone.target_id
                    drone.assess_start = self.t
                    drone.state        = "ASSESS"
                    drone.known[drone.target_id].update({
                        "status":     "assessing",
                        "claimed_by": drone.id,
                        "ts":         self.t,
                    })
                else:
                    step    = min(SPEED * DT, d)
                    drone.x += (tx - drone.x) / d * step
                    drone.y += (ty - drone.y) / d * step
                    drone.state = "MOVE"

            else:
                # No known unclaimed survivors → search open field
                wx, wy = drone.waypoint
                d = _dist(drone.x, drone.y, wx, wy)
                if d < 2.0:
                    # Pick next waypoint: spread-out for gossip/centralized,
                    # random for random protocol
                    drone.waypoint = self._pick_waypoint(drone)
                else:
                    step    = min(SPEED * DT, d)
                    drone.x += (wx - drone.x) / d * step
                    drone.y += (wy - drone.y) / d * step
                drone.state = "SEARCH"

    # ── termination ───────────────────────────────────────────────
    def _check_done(self):
        if len(self.assessed_ids) == N_SURV:
            self.t_all = self.t
            self.done  = True
        elif self.t >= T_MAX:
            self.done = True

    # ── step / run ────────────────────────────────────────────────
    def step(self):
        if self.done:
            return
        self._detect()
        self._comm()
        self._move()
        self._check_done()
        self.t += DT

    def run(self):
        while not self.done:
            self.step()
        return self.metrics()

    def metrics(self):
        return {
            "time_all_assessed": self.t_all,
            "all_found":         len(self.assessed_ids) == N_SURV,
            "assessed_count":    len(self.assessed_ids),
            "first_crit_time":   self.first_crit_t,
            "n_critical":        self.n_critical,
            "n_dup":             self.n_dup,
            "bytes_tx":          self.bytes_tx,
            "n_msgs":            self.n_msgs,
            "protocol":          self.protocol,
            "p_loss":            self.p_loss,
            "ge_model":          self.ge_model,
        }


# ══════════════════════════════════════════════════════════════════════
#  ANIMATED VISUALIZER
# ══════════════════════════════════════════════════════════════════════
COMM_FADE   = 8
TICKS_PER_F = 3

_D_CLR = {"SEARCH": "#FFD740", "MOVE": "#FF9800", "ASSESS": "#F44336"}
_S_CLR = {
    "detected":  "#69F0AE",
    "claimed":   "#FF9800",
    "assessing": "#FF5252",
    "assessed":  "#FFFFFF",
    "critical":  "#FF5252",
    "normal":    "#69F0AE",
}


def run_visualize(protocol="gossip", p_loss=0.0, ge_model=False, seed=0):
    sim = SwarmSim(protocol=protocol, p_loss=p_loss,
                   ge_model=ge_model, seed=seed)

    fig = plt.figure(figsize=(16, 8.5), facecolor="#12121f")
    gs  = GridSpec(3, 3, figure=fig,
                   width_ratios=[4, 1.3, 1.5],
                   height_ratios=[0.9, 3, 0.55],
                   hspace=0.40, wspace=0.30)

    ax_map  = fig.add_subplot(gs[:2, 0])
    ax_stat = fig.add_subplot(gs[0,  1])
    ax_cnt  = fig.add_subplot(gs[1,  1])
    ax_bar  = fig.add_subplot(gs[1,  2])
    ax_leg  = fig.add_subplot(gs[2,  :])

    BG = "#0b0b18"
    for ax in (ax_map, ax_stat, ax_cnt, ax_bar, ax_leg):
        ax.set_facecolor(BG)

    plabel, _ = PROTO_INFO[protocol]
    llabel = "GE burst-loss" if ge_model else f"P_loss = {p_loss:.0%}"
    fig.suptitle(
        f"R.A.M.P.A.T. Swarm Simulation  ·  {plabel}  ·  {llabel}\n"
        f"{N_DRONES} drones  ·  {N_SURV} survivors  ·  {FIELD}×{FIELD} m field",
        color="white", fontsize=11, fontweight="bold", y=0.99, va="top"
    )

    ax_map.set_xlim(-5, FIELD + 5); ax_map.set_ylim(-5, FIELD + 5)
    ax_map.set_aspect("equal")
    ax_map.set_xlabel("X (m)", color="#9999bb", fontsize=9)
    ax_map.set_ylabel("Y (m)", color="#9999bb", fontsize=9)
    ax_map.tick_params(colors="#9999bb", labelsize=7)
    for sp in ax_map.spines.values(): sp.set_color("#222244")
    ax_map.grid(True, color="#1a1a33", lw=0.4)

    s_init_clr = [
        _S_CLR["critical"] if s.critical else _S_CLR["normal"]
        for s in sim.survivors
    ]
    surv_sc = ax_map.scatter(
        [s.x for s in sim.survivors], [s.y for s in sim.survivors],
        c=s_init_clr, s=95, marker="*",
        edgecolors="white", linewidths=0.5, zorder=4
    )
    drone_sc = ax_map.scatter(
        [d.x for d in sim.drones], [d.y for d in sim.drones],
        c=[_D_CLR["SEARCH"]] * N_DRONES, s=140, marker="^",
        edgecolors="white", linewidths=0.7, zorder=5
    )
    # Waypoint lines (dashed) — shows where each drone is heading
    wp_lines = [
        ax_map.plot([], [], color="#444466", lw=0.8, ls="--", zorder=1)[0]
        for _ in sim.drones
    ]

    assess_circles = [
        plt.Circle((0,0), R_ASSESS, color="#FFD740",
                   fill=False, lw=1.4, alpha=0.0)
        for _ in sim.drones
    ]
    detect_circles = [
        plt.Circle((0,0), R_DETECT, color="#64B5F6",
                   fill=False, lw=0.5, ls="--", alpha=0.0)
        for _ in sim.drones
    ]
    for c in assess_circles + detect_circles:
        ax_map.add_patch(c)

    MAX_CL = 80
    cl_pool, comm_q = [], []

    ax_stat.axis("off")
    stat_txt = ax_stat.text(
        0.05, 0.97, "", transform=ax_stat.transAxes,
        color="white", fontsize=8.5, va="top", fontfamily="monospace"
    )

    ax_cnt.set_xlim(0, 1); ax_cnt.set_ylim(-0.3, N_SURV + 0.3)
    ax_cnt.set_xlabel("Time (s)", color="#9999bb", fontsize=7)
    ax_cnt.set_ylabel("# Assessed", color="#9999bb", fontsize=7)
    ax_cnt.set_title("Survivors Assessed", color="white", fontsize=8.5)
    ax_cnt.tick_params(colors="#9999bb", labelsize=6)
    for sp in ax_cnt.spines.values(): sp.set_color("#222244")
    ax_cnt.grid(True, color="#1a1a33", lw=0.3)
    cnt_line, = ax_cnt.plot([], [], color="#69F0AE", lw=2)
    t_hist, cnt_hist = [], []
    crit_marked = False

    ax_bar.set_ylim(0, N_DRONES + 0.5)
    ax_bar.set_title("Drone States", color="white", fontsize=8.5)
    ax_bar.tick_params(colors="#9999bb", labelsize=7)
    for sp in ax_bar.spines.values(): sp.set_color("#222244")
    ax_bar.grid(True, color="#1a1a33", lw=0.3, axis="y")
    state_bars = ax_bar.bar(
        ["SEARCH", "MOVE", "ASSESS"], [N_DRONES, 0, 0],
        color=[_D_CLR["SEARCH"], _D_CLR["MOVE"], _D_CLR["ASSESS"]],
        edgecolor="white", linewidth=0.4, width=0.55
    )
    ax_bar.set_yticks(range(0, N_DRONES + 1))
    ax_bar.tick_params(axis="x", labelsize=7, colors="white")

    ax_leg.axis("off")
    leg_handles = [
        Line2D([0],[0], marker="^", color="w",
               markerfacecolor=_D_CLR["SEARCH"], markersize=9,
               label="Drone – searching"),
        Line2D([0],[0], marker="^", color="w",
               markerfacecolor=_D_CLR["MOVE"], markersize=9,
               label="Drone – en route"),
        Line2D([0],[0], marker="^", color="w",
               markerfacecolor=_D_CLR["ASSESS"], markersize=9,
               label="Drone – assessing"),
        Line2D([0],[0], marker="*", color="w",
               markerfacecolor=_S_CLR["normal"], markersize=11,
               label="Survivor (detected)"),
        Line2D([0],[0], marker="*", color="w",
               markerfacecolor=_S_CLR["claimed"], markersize=11,
               label="Survivor (claimed)"),
        Line2D([0],[0], marker="*", color="w",
               markerfacecolor=_S_CLR["assessing"], markersize=11,
               label="Survivor (assessing)"),
        Line2D([0],[0], marker="*", color="w",
               markerfacecolor=_S_CLR["assessed"], markersize=11,
               label="Survivor (done ✓)"),
        mpatches.Patch(color="#CE93D8", alpha=0.8,  label="Comm link"),
        mpatches.Patch(color="#444466", alpha=0.8,  label="Search waypoint"),
        mpatches.Patch(color="#64B5F6", alpha=0.25, label="Detect zone"),
    ]
    ax_leg.legend(
        handles=leg_handles, loc="center", ncol=5,
        fontsize=7.5, facecolor=BG, labelcolor="white",
        edgecolor="#333355", framealpha=0.9
    )

    def update(frame):
        nonlocal crit_marked
        for _ in range(TICKS_PER_F):
            if not sim.done: sim.step()

        d_xy  = np.array([[d.x, d.y] for d in sim.drones])
        d_clr = [_D_CLR.get(d.state, _D_CLR["SEARCH"]) for d in sim.drones]
        drone_sc.set_offsets(d_xy)
        drone_sc.set_color(d_clr)

        for i, drone in enumerate(sim.drones):
            assess_circles[i].center = (drone.x, drone.y)
            detect_circles[i].center = (drone.x, drone.y)
            assess_circles[i].set_alpha(0.38 if drone.state=="ASSESS" else 0.0)
            detect_circles[i].set_alpha(0.13 if drone.state=="SEARCH" else 0.0)
            # Draw waypoint line
            if drone.state == "SEARCH" and drone.target_id is None:
                wx, wy = drone.waypoint
                wp_lines[i].set_data([drone.x, wx], [drone.y, wy])
                wp_lines[i].set_alpha(0.5)
            else:
                wp_lines[i].set_alpha(0.0)

        s_clr, s_sz = [], []
        for s in sim.survivors:
            best = None
            for d in sim.drones:
                if s.id in d.known:
                    st = d.known[s.id]["status"]
                    if best is None or _RANK.get(st,0) > _RANK.get(best,0):
                        best = st
            if best is None:
                clr, sz = (_S_CLR["critical"] if s.critical
                           else _S_CLR["normal"]), 95
            elif best == "assessed":   clr, sz = _S_CLR["assessed"],  60
            elif best == "assessing":  clr, sz = _S_CLR["assessing"], 120
            elif best == "claimed":    clr, sz = _S_CLR["claimed"],   100
            else:                      clr, sz = _S_CLR["detected"],   95
            s_clr.append(clr); s_sz.append(sz)
        surv_sc.set_color(s_clr)
        surv_sc.set_sizes(s_sz)

        while sim.comm_flash:
            comm_q.append(sim.comm_flash.pop(0))
        if len(comm_q) > MAX_CL:
            comm_q[:] = comm_q[-MAX_CL:]
        while len(cl_pool) < len(comm_q):
            ln, = ax_map.plot([], [], color="#CE93D8", lw=0.8, alpha=0.0, zorder=2)
            cl_pool.append(ln)
        for ln in cl_pool: ln.set_alpha(0.0)
        dead = []
        for i, ev in enumerate(comm_q):
            alpha = max(0.0, (COMM_FADE-ev[4])/COMM_FADE*0.75)
            if i < len(cl_pool):
                cl_pool[i].set_data([ev[0],ev[2]], [ev[1],ev[3]])
                cl_pool[i].set_alpha(alpha)
            ev[4] += 1
            if ev[4] >= COMM_FADE: dead.append(i)
        for i in reversed(dead):
            if i < len(comm_q): comm_q.pop(i)

        n_a  = len(sim.assessed_ids)
        rate = n_a / max(sim.t, 1) * 60
        fct  = sim.first_crit_t
        stat_txt.set_text(
            f"  Time:      {sim.t:>8.0f} s\n"
            f"  Assessed:  {n_a:>4} / {N_SURV}\n"
            f"  Critical:  {sim.n_critical}\n"
            f"  1st Crit:  " +
            (f"{fct:>8.0f} s\n" if fct else "       —\n") +
            f"  Rate:      {rate:>5.2f}/min\n"
            f"  Msgs sent: {sim.n_msgs:>7}\n"
            f"  kBytes TX: {sim.bytes_tx/1000:>6.1f}\n"
            f"  Dup scans: {sim.n_dup:>5}\n" +
            ("  STATUS:    DONE ✓\n" if sim.done else
             "  STATUS:    Running…\n")
        )
        t_hist.append(sim.t); cnt_hist.append(n_a)
        if t_hist: ax_cnt.set_xlim(0, max(t_hist)*1.05 or 1)
        cnt_line.set_data(t_hist, cnt_hist)
        if fct and not crit_marked:
            ax_cnt.axvline(x=fct, color="#FF5252", lw=1.2, ls=":")
            ax_cnt.text(fct, N_SURV*0.85, " 1st\n crit",
                        color="#FF5252", fontsize=6)
            crit_marked = True

        sc = {"SEARCH":0,"MOVE":0,"ASSESS":0}
        for d in sim.drones:
            sc[d.state if d.state in sc else "SEARCH"] += 1
        for bar, k in zip(state_bars, ["SEARCH","MOVE","ASSESS"]):
            bar.set_height(sc[k])

        return (drone_sc, surv_sc,
                *assess_circles, *detect_circles, *wp_lines,
                cnt_line, stat_txt, *state_bars)

    ani = animation.FuncAnimation(
        fig, update, frames=None, interval=50,
        blit=False, cache_frame_data=False,
    )
    plt.show()
    return sim.metrics()


