#  BATCH BENCHMARK
# ══════════════════════════════════════════════════════════════════════
def run_benchmark(n_trials=N_TRIALS):
    os.makedirs("sim_data", exist_ok=True)
    records = []
    configs = (
        [(p, pl, False)
         for p in ("gossip","random","centralized")
         for pl in P_LOSS_LIST]
        + [(p, 0.0, True) for p in ("gossip","random")]
    )
    total = len(configs) * n_trials
    print(f"\n  ▶  Benchmark | {n_trials} trials per condition")
    print(f"  {len(configs)} conditions × {n_trials} trials = {total} total runs")
    print("  (Ctrl-C to cancel)\n")

    with tqdm(total=total, desc="Benchmarking", unit="trial") as pbar:
        for proto, ploss, ge in configs:
            for trial in range(n_trials):
                m = SwarmSim(protocol=proto, p_loss=ploss,
                             ge_model=ge, seed=trial).run()
                m["trial"]      = trial
                m["loss_model"] = "gilbert_elliott" if ge else "bernoulli"
                records.append(m)
                pbar.update(1)

    df = pd.DataFrame(records)
    df["all_found"] = df["all_found"].astype(bool)
    df["ge_model"]  = df["ge_model"].astype(bool)
    path = "sim_data/swarm_results.csv"
    df.to_csv(path, index=False)
    print(f"\n  ✓  {len(df)} records  →  {path}")
    _print_table(df)
    return df


