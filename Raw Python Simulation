def _run_stats(b, ge):
    print("\n"+"═"*68)
    print("  STATISTICAL SIGNIFICANCE TESTS")
    print("═"*68)

    def _ttest(ga, gb, label):
        a=ga["time_all_assessed"].dropna().values
        bv=gb["time_all_assessed"].dropna().values
        if min(len(a),len(bv))<2:
            print(f"  {label}: insufficient data"); return
        t,p=scipy_stats.ttest_ind(a,bv,equal_var=False)
        d=(a.mean()-bv.mean())/np.sqrt((a.std()**2+bv.std()**2)/2)
        sig=("***" if p<0.001 else "**" if p<0.01 else "*" if p<0.05 else "ns")
        print(f"\n  {label}")
        print(f"    A: {a.mean():.1f} ± {a.std():.1f} s"
              f"   B: {bv.mean():.1f} ± {bv.std():.1f} s")
        print(f"    Welch t={t:+.3f}   p={p:.5f}  {sig}"
              f"   Cohen's d={d:.3f}")

    _ttest(b[(b.protocol=="gossip")&(b.p_loss==0.0)],
           b[(b.protocol=="centralized")&(b.p_loss==0.0)],
           "H1 · Gossip(0%) vs Centralized(0%)")
    _ttest(b[(b.protocol=="gossip")&(b.p_loss==0.5)],
           b[(b.protocol=="gossip")&(b.p_loss==0.0)],
           "H2 · Gossip(50%) vs Gossip(0%)  ← KEY")
    _ttest(b[(b.protocol=="gossip")&(b.p_loss==0.8)],
           b[(b.protocol=="gossip")&(b.p_loss==0.0)],
           "H3 · Gossip(80%) vs Gossip(0%)")
    _ttest(b[(b.protocol=="gossip")&(b.p_loss==0.5)],
           b[(b.protocol=="random")&(b.p_loss==0.5)],
           "H4 · Gossip(50%) vs Random(50%)  ← coordination benefit")
    _ttest(b[(b.protocol=="gossip")&(b.p_loss==0.0)],
           b[(b.protocol=="random")&(b.p_loss==0.0)],
           "H5 · Gossip(0%) vs Random(0%)   ← baseline")
    if len(ge):
        _ttest(ge[ge.protocol=="gossip"],ge[ge.protocol=="random"],
               "H6 · GE-Gossip vs GE-Random")

    print("\n  ── Duplicate Scan Tests ────────────────────────────────────")
    for pl in [0.0,0.5,0.8]:
        gd=b[(b.protocol=="gossip")&(b.p_loss==pl)]["n_dup"].dropna().values
        rd=b[(b.protocol=="random")&(b.p_loss==pl)]["n_dup"].dropna().values
        if min(len(gd),len(rd))<2: continue
        t,p=scipy_stats.ttest_ind(gd,rd,equal_var=False)
        d=(gd.mean()-rd.mean())/np.sqrt((gd.std()**2+rd.std()**2)/2)
        sig=("***" if p<0.001 else "**" if p<0.01 else "*" if p<0.05 else "ns")
        print(f"\n  Dup: Gossip({int(pl*100)}%) vs Random({int(pl*100)}%)")
        print(f"    Gossip={gd.mean():.2f}±{gd.std():.2f}"
              f"  Random={rd.mean():.2f}±{rd.std():.2f}")
        print(f"    t={t:+.3f}  p={p:.5f}  {sig}  d={d:.3f}")

    c0 =b[(b.protocol=="centralized")&(b.p_loss==0.0)]["time_all_assessed"].dropna()
    g50=b[(b.protocol=="gossip")&(b.p_loss==0.5)]["time_all_assessed"].dropna()
    if len(c0) and len(g50):
        ratio=g50.mean()/c0.mean(); eff=1.0/ratio
        print(f"\n  ── Key Efficiency Result ─────────────────────────────────")
        print(f"  Centralized(0%) : {c0.mean():.1f} s")
        print(f"  Gossip(50%)     : {g50.mean():.1f} s")
        print(f"  Efficiency      : {eff:.1%}")
        print(f"  ≥85% met?       : {'YES ✓' if eff>=0.85 else 'NO ✗'}")

    g0=b[(b.protocol=="gossip")&(b.p_loss==0.0)]["time_all_assessed"].dropna()
    r0=b[(b.protocol=="random")&(b.p_loss==0.0)]["time_all_assessed"].dropna()
    if len(g0) and len(r0):
        su=r0.mean()/g0.mean()
        print(f"\n  Speed-up vs Random (0%) : {su:.2f}×")
        print(f"  ≥2× met?                : {'YES ✓' if su>=2.0 else 'NO ✗'}")
    print("═"*68+"\n")


