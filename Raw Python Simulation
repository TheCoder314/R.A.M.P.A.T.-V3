                    choices=["gossip","random","centralized"],
                    default="gossip")
    ap.add_argument("--ploss",  type=float, default=0.0)
    ap.add_argument("--ge",     action="store_true")
    ap.add_argument("--seed",   type=int,   default=42)
    ap.add_argument("--trials", type=int,   default=N_TRIALS)
    args = ap.parse_args()

    if args.mode == "visualize":
        print(f"\n  ▶  Visualize | {args.protocol} | "
              f"p_loss={args.ploss:.0%} | GE={args.ge} | seed={args.seed}")
        m = run_visualize(protocol=args.protocol, p_loss=args.ploss,
                          ge_model=args.ge, seed=args.seed)
        print(f"\n  Final metrics: {m}")
    elif args.mode == "benchmark":
        run_benchmark(n_trials=args.trials)
    elif args.mode == "analyze":
        print("\n  ▶  Analyze | loading sim_data/swarm_results.csv")
        run_analyze()


if __name__ == "__main__":
    main()
